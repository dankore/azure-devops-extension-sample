{
    "contributions": [
        {
            "id": "global-wiki-page-creator-widget",
            "type": "ms.vss-dashboards-web.widget",
            "targets": [
                "ms.vss-dashboards-web.widget-catalog"
            ],
            "properties": {
                "name": "Global Wiki Page Creator",
                "description": "Create a wiki page in any project from your dashboard. Pick project, wiki, page path, and content.",
                "catalogIconUrl": "static/global-wiki-page-creator-logo.png",
                "uri": "dist/global-wiki-page-creator/global-wiki-page-creator.html",
                "isNameConfigurable": true,
                "supportedSizes": [
                    { "rowSpan": 2, "columnSpan": 2 },
                    { "rowSpan": 2, "columnSpan": 3 }
                ],
                "supportedScopes": [ "project_team" ]
            }
        }
    ],
    "scopes": [
        "vso.project",
        "vso.wiki_write"
    ]
}
