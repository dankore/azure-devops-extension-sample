{
    "contributions": [
        {
            "id": "global-wiki-page-viewer-widget",
            "type": "ms.vss-dashboards-web.widget",
            "targets": [
                "ms.vss-dashboards-web.widget-catalog"
            ],
            "properties": {
                "name": "Global Wiki Page Viewer",
                "description": "View wiki pages from any project in a modal on your dashboard.",
                "catalogIconUrl": "static/global-wiki-page-viewer-logo.png",
                "uri": "dist/global-wiki-page-viewer/global-wiki-page-viewer.html",
                "isNameConfigurable": true,
                "supportedSizes": [
                    { "rowSpan": 2, "columnSpan": 2 },
                    { "rowSpan": 2, "columnSpan": 3 }
