{
    "manifestVersion": 1,
    "id": "global-wiki-page-viewer",
    "publisher": "dankore-software",
    "version": "1.0.8",
    "name": "Global Wiki Page Viewer",
    "description": "View wiki pages from any project in a modal on your dashboard.",
    "categories": [
        "Azure Repos"
    ],
    "public": false,
    "targets": [
        {
            "id": "Microsoft.VisualStudio.Services"
        }
    ],
    "icons": {
        "default": "static/global-wiki-page-viewer-logo.png"
    },
    "content": {
        "details": {
            "path": "overview.md"
        }
    },
    "files": [
        {
            "path": "static",
            "addressable": true
        },
        {
            "path": "dist",
            "addressable": true
        }
    ]
}

