{
    "manifestVersion": 1,
    "id": "global-wiki-page-creator",
    "publisher": "dankore-software",
    "version": "1.0.4",
    "name": "Global Wiki Page Creator",
    "description": "Create a wiki page in any project from your dashboard. Pick project, wiki, page path, and content.",
    "categories": [
        "Azure Repos"
    ],
    "public": false,
    "targets": [
        {
            "id": "Microsoft.VisualStudio.Services"
        }
    ],
    "icons": {
        "default": "static/global-wiki-page-creator-logo.png"
    },
    "content": {
        "details": {
            "path": "overview.md"
        }
    },
    "files": [
        {
            "path": "static",
            "addressable": true
        },
        {
            "path": "dist",
            "addressable": true
        }
    ]
}
